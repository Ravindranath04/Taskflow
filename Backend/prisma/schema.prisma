// Copy this entire content into your Backend/prisma/schema.prisma file
// (rename from schema.txt to schema.prisma after downloading)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  role      UserRole @default(MEMBER)
  color     String   @default("#7C3AED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile         EmployeeProfile?
  ownedProjects   Project[]        @relation("ProjectOwner")
  projectMembers  ProjectMember[]
  assignedTasks   Task[]           @relation("TaskAssignee")
  createdTasks    Task[]           @relation("TaskCreator")
  comments        Comment[]
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  taskRatings     TaskRating[]     @relation("RatedBy")
  receivedRatings TaskRating[]     @relation("RatedUser")

  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
}

// ─── EMPLOYEE PROFILE ─────────────────────────────────────────────────────────

model EmployeeProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String?
  bio             String?
  department      String?
  yearsExperience Int      @default(0)
  joinedAt        DateTime @default(now())

  skills          String[]
  techStack       String[]
  domains         String[]

  performanceScore  Float  @default(0)
  avgTaskRating     Float  @default(0)
  tasksCompleted    Int    @default(0)
  tasksOnTime       Int    @default(0)
  tasksLate         Int    @default(0)
  currentWorkload   Int    @default(0)

  linkedinUrl     String?
  githubUrl       String?

  updatedAt       DateTime @updatedAt

  @@map("employee_profiles")
}

// ─── PROJECT ──────────────────────────────────────────────────────────────────

model Project {
  id               String        @id @default(cuid())
  name             String
  description      String?
  color            String        @default("#7C3AED")
  status           ProjectStatus @default(PLANNING)
  deadline         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  completionRating Int?
  completionNotes  String?

  ownerId  String
  owner    User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members  ProjectMember[]
  tasks    Task[]

  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model ProjectMember {
  id       String   @id @default(cuid())
  role     String   @default("member")
  joinedAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── TASK ─────────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  tags        String[]
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  requiredSkills  String[]
  requiredDomains String[]
  autoAssigned    Boolean  @default(false)
  assignmentScore Float?

  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId  String
  creator    User     @relation("TaskCreator", fields: [creatorId], references: [id])

  comments Comment[]
  ratings  TaskRating[]

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// ─── TASK RATING ──────────────────────────────────────────────────────────────

model TaskRating {
  id        String   @id @default(cuid())
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  taskId      String
  task        Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  ratedUserId String
  ratedUser   User   @relation("RatedUser", fields: [ratedUserId], references: [id])
  ratedById   String
  ratedBy     User   @relation("RatedBy", fields: [ratedById], references: [id])

  @@unique([taskId, ratedById])
  @@map("task_ratings")
}

// ─── COMMENT ──────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("comments")
}

// ─── NOTIFICATION ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── REFRESH TOKEN ────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}